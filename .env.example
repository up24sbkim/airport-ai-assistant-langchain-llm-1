# Upstage Solar API Key
UPSTAGE_API_KEY=your_upstage_solar_api_key_here

# 모델명은 수업/계정에서 사용하는 Solar 모델명으로 바꿔도 됩니다.
SOLAR_MODEL=solar-pro3

# 옵션: LangSmith 쓰는 경우만 입력
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=airport-assistant

# 공공데이터포털 인천공항 운항정보 API 서비스 키
ICN_API_SERVICE_KEY=your_icn_api_service_key_here

# Google Maps Directions API 키
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here